# ===========================================================================
# Copy this to .env and fill in real values. NEVER commit .env to git.
# ===========================================================================

# App
ENVIRONMENT=development

# Database (overridden by docker-compose for the api container)
DATABASE_URL=postgresql+asyncpg://copilot:copilot_dev_password@localhost:5432/interview_copilot

# Auth — generate a strong key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# AI providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000
